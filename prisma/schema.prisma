generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN    @map("admin")
  ESTOQUE  @map("estoque")
  CONSULTA @map("consulta")

  @@map("user_role")
}

enum RecordStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("record_status")
}

enum ProductType {
  WINE      @map("wine")
  SPARKLING @map("sparkling")

  @@map("product_type")
}

enum WineColor {
  RED   @map("red")
  WHITE @map("white")
  ROSE  @map("rose")

  @@map("wine_color")
}

enum LocationType {
  SHELF         @map("shelf")
  WOODEN_CELLAR @map("wooden_cellar")
  DISPLAY       @map("display")
  OTHER         @map("other")

  @@map("location_type")
}

enum MovementType {
  ENTRY      @map("entry")
  EXIT       @map("exit")
  TRANSFER   @map("transfer")
  ADJUSTMENT @map("adjustment")
  INVENTORY  @map("inventory")
  LOSS       @map("loss")
  REVERSAL   @map("reversal")

  @@map("movement_type")
}

enum MovementStatus {
  ACTIVE   @map("active")
  REVERSED @map("reversed")

  @@map("movement_status")
}

enum AuditStatus {
  PENDING   @map("pending")
  CONFIRMED @map("confirmed")
  ADJUSTED  @map("adjusted")
  IGNORED   @map("ignored")

  @@map("audit_status")
}

enum ImportStatus {
  DRAFT     @map("draft")
  VALIDATED @map("validated")
  IMPORTED  @map("imported")
  FAILED    @map("failed")

  @@map("import_status")
}

enum SecurityEventType {
  LOGIN_SUCCESS      @map("login_success")
  LOGIN_FAILURE      @map("login_failure")
  LOGIN_LOCKOUT      @map("login_lockout")
  LOGOUT             @map("logout")
  PASSWORD_CHANGE    @map("password_change")
  PASSWORD_RESET     @map("password_reset")
  USER_CREATED       @map("user_created")
  USER_INACTIVATED   @map("user_inactivated")
  USER_REACTIVATED   @map("user_reactivated")
  MFA_SUCCESS        @map("mfa_success")
  MFA_FAILURE        @map("mfa_failure")
  MFA_ENABLED        @map("mfa_enabled")
  MFA_RESET          @map("mfa_reset")
  RECOVERY_CODE_USED @map("recovery_code_used")

  @@map("security_event_type")
}

enum BarcodeLookupStatus {
  FOUND     @map("found")
  NOT_FOUND @map("not_found")
  AMBIGUOUS @map("ambiguous")

  @@map("barcode_lookup_status")
}

enum BarcodeLookupSource {
  INPUT      @map("input")
  CAMERA     @map("camera")
  DIRECT_URL @map("direct_url")
  API        @map("api")

  @@map("barcode_lookup_source")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         UserRole     @default(CONSULTA)
  status       RecordStatus @default(ACTIVE)
  mustChangePassword Boolean @default(true) @map("must_change_password")
  passwordChangedAt DateTime? @map("password_changed_at")
  failedLoginAttempts Int    @default(0) @map("failed_login_attempts")
  lockedUntil  DateTime?    @map("locked_until")
  lastLoginAt  DateTime?    @map("last_login_at")
  sessionVersion Int        @default(0) @map("session_version")
  mfaEnabled Boolean        @default(false) @map("mfa_enabled")
  mfaSecretEncrypted String? @map("mfa_secret_encrypted")
  mfaPendingSecretEncrypted String? @map("mfa_pending_secret_encrypted")
  mfaPendingSecretCreatedAt DateTime? @map("mfa_pending_secret_created_at")
  mfaConfirmedAt DateTime?  @map("mfa_confirmed_at")
  mfaFailedAttempts Int     @default(0) @map("mfa_failed_attempts")
  mfaLockedUntil DateTime?  @map("mfa_locked_until")
  mfaLastUsedCounter BigInt? @map("mfa_last_used_counter")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  movements     StockMovement[]
  inventoryAudits InventoryAudit[]
  importBatches ImportBatch[]
  mfaRecoveryCodes MfaRecoveryCode[]
  barcodeLookups BarcodeLookup[]
  securityEventsActed SecurityEvent[] @relation("SecurityEventActor")
  securityEventsSubject SecurityEvent[] @relation("SecurityEventSubject")

  @@map("users")
}

model MfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("mfa_recovery_codes")
}

model SecurityEvent {
  id            String            @id @default(uuid()) @db.Uuid
  eventType     SecurityEventType @map("event_type")
  actorUserId   String?           @map("actor_user_id") @db.Uuid
  subjectUserId String?           @map("subject_user_id") @db.Uuid
  email         String?
  ipAddress     String?           @map("ip_address")
  userAgent     String?           @map("user_agent")
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")

  actorUser   User? @relation("SecurityEventActor", fields: [actorUserId], references: [id])
  subjectUser User? @relation("SecurityEventSubject", fields: [subjectUserId], references: [id])

  @@index([eventType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([subjectUserId, createdAt])
  @@index([email, createdAt])
  @@map("security_events")
}

model Supplier {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  document  String?
  phone     String?
  email     String?
  notes     String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  productFamilies ProductFamily[]
  products        Product[]
  movements       StockMovement[]

  @@index([name])
  @@map("suppliers")
}

model ProductFamily {
  id             String      @id @default(uuid()) @db.Uuid
  normalizedName String      @map("normalized_name")
  displayName    String      @map("display_name")
  type           ProductType
  supplierId     String?     @map("supplier_id") @db.Uuid
  supplierKey    String      @default("sem_fornecedor") @map("supplier_key")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id])
  products Product[]

  @@unique([normalizedName, type, supplierKey], map: "product_families_unique_identity")
  @@index([displayName])
  @@map("product_families")
}

model Product {
  id              String       @id @default(uuid()) @db.Uuid
  productFamilyId String       @map("product_family_id") @db.Uuid
  sku             String       @unique
  name            String
  type            ProductType
  wineColor       WineColor     @map("wine_color")
  grape           String
  country         String?
  supplierId      String?      @map("supplier_id") @db.Uuid
  vintage         String?
  barcode         String?
  costPrice       Decimal?     @map("cost_price") @db.Decimal(12, 2)
  salePrice       Decimal?     @map("sale_price") @db.Decimal(12, 2)
  photoUrl        String?      @map("photo_url")
  notes           String?
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  productFamily ProductFamily @relation(fields: [productFamilyId], references: [id])
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  balances      InventoryBalance[]
  movements     StockMovement[]
  movementLines StockMovementLine[]
  inventoryAudits InventoryAudit[]
  barcodeLookups BarcodeLookup[]

  @@index([name])
  @@index([barcode])
  @@index([wineColor])
  @@index([grape])
  @@index([productFamilyId, barcode])
  @@map("products")
}

model BarcodeLookup {
  id                  String              @id @default(uuid()) @db.Uuid
  barcode             String
  status              BarcodeLookupStatus
  source              BarcodeLookupSource @default(DIRECT_URL)
  matchedProductId    String?             @map("matched_product_id") @db.Uuid
  matchedProductCount Int                 @default(0) @map("matched_product_count")
  userId              String?             @map("user_id") @db.Uuid
  ipAddress           String?             @map("ip_address")
  userAgent           String?             @map("user_agent")
  createdAt           DateTime            @default(now()) @map("created_at")

  matchedProduct Product? @relation(fields: [matchedProductId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@index([barcode, createdAt])
  @@index([status, createdAt])
  @@index([matchedProductId, createdAt])
  @@index([userId, createdAt])
  @@map("barcode_lookups")
}

model StorageLocation {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  code        String       @unique
  type        LocationType
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  balances             InventoryBalance[]
  sourceMovements      StockMovement[] @relation("MovementSourceLocation")
  destinationMovements StockMovement[] @relation("MovementDestinationLocation")
  affectedMovements    StockMovement[] @relation("MovementAffectedLocation")
  movementLines        StockMovementLine[]
  inventoryAudits      InventoryAudit[]

  @@index([name])
  @@map("storage_locations")
}

model InventoryBalance {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  storageLocationId String   @map("storage_location_id") @db.Uuid
  quantity          Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product         Product         @relation(fields: [productId], references: [id])
  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id])

  @@unique([productId, storageLocationId], map: "inventory_balances_product_location_unique")
  @@index([storageLocationId])
  @@map("inventory_balances")
}

model StockMovement {
  id                    String         @id @default(uuid()) @db.Uuid
  productId             String         @map("product_id") @db.Uuid
  movementType          MovementType   @map("movement_type")
  quantity              Int
  sourceLocationId      String?        @map("source_location_id") @db.Uuid
  destinationLocationId String?        @map("destination_location_id") @db.Uuid
  affectedLocationId    String?        @map("affected_location_id") @db.Uuid
  supplierId            String?        @map("supplier_id") @db.Uuid
  inventoryAuditId      String?        @unique @map("inventory_audit_id") @db.Uuid
  importBatchId         String?        @map("import_batch_id") @db.Uuid
  idempotencyKey        String?        @unique @map("idempotency_key")
  reason                String?
  notes                 String?
  userId                String         @map("user_id") @db.Uuid
  status                MovementStatus @default(ACTIVE)
  reversedMovementId    String?        @unique @map("reversed_movement_id") @db.Uuid
  occurredAt            DateTime       @default(now()) @map("occurred_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  product             Product          @relation(fields: [productId], references: [id])
  sourceLocation      StorageLocation? @relation("MovementSourceLocation", fields: [sourceLocationId], references: [id])
  destinationLocation StorageLocation? @relation("MovementDestinationLocation", fields: [destinationLocationId], references: [id])
  affectedLocation    StorageLocation? @relation("MovementAffectedLocation", fields: [affectedLocationId], references: [id])
  supplier            Supplier?        @relation(fields: [supplierId], references: [id])
  inventoryAudit      InventoryAudit?  @relation(fields: [inventoryAuditId], references: [id])
  importBatch         ImportBatch?     @relation(fields: [importBatchId], references: [id])
  user                User             @relation(fields: [userId], references: [id])
  reversedMovement    StockMovement?   @relation("MovementReversal", fields: [reversedMovementId], references: [id])
  reversalMovement    StockMovement?   @relation("MovementReversal")
  lines               StockMovementLine[]

  @@index([productId, createdAt])
  @@index([movementType])
  @@index([status])
  @@index([sourceLocationId])
  @@index([destinationLocationId])
  @@index([affectedLocationId])
  @@map("stock_movements")
}

model StockMovementLine {
  id                String   @id @default(uuid()) @db.Uuid
  stockMovementId   String   @map("stock_movement_id") @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  storageLocationId String   @map("storage_location_id") @db.Uuid
  quantityBefore    Int      @map("quantity_before")
  quantityDelta     Int      @map("quantity_delta")
  quantityAfter     Int      @map("quantity_after")
  createdAt         DateTime @default(now()) @map("created_at")

  stockMovement  StockMovement  @relation(fields: [stockMovementId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id])

  @@unique([stockMovementId, storageLocationId], map: "stock_movement_lines_movement_location_unique")
  @@index([productId])
  @@index([storageLocationId])
  @@map("stock_movement_lines")
}

model InventoryAudit {
  id                String      @id @default(uuid()) @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  storageLocationId String      @map("storage_location_id") @db.Uuid
  expectedQuantity  Int         @map("expected_quantity")
  countedQuantity   Int         @map("counted_quantity")
  difference        Int
  status            AuditStatus @default(PENDING)
  idempotencyKey    String?     @unique @map("idempotency_key")
  notes             String?
  userId            String      @map("user_id") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at")

  product         Product         @relation(fields: [productId], references: [id])
  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  adjustmentMovement StockMovement?

  @@index([status])
  @@index([productId, storageLocationId])
  @@map("inventory_audits")
}

model ImportBatch {
  id        String       @id @default(uuid()) @db.Uuid
  fileName  String       @map("file_name")
  fileHash  String       @unique @map("file_hash")
  status    ImportStatus @default(DRAFT)
  totalRows Int          @default(0) @map("total_rows")
  validRows Int          @default(0) @map("valid_rows")
  errorRows Int          @default(0) @map("error_rows")
  userId    String       @map("user_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id])
  movements StockMovement[]

  @@index([status])
  @@map("import_batches")
}
